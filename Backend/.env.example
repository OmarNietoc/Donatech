# ================================================================
# DONATECH — Variables de entorno
# Copiar este archivo a .env y completar los valores reales.
# NUNCA subir el archivo .env al repositorio.
# ================================================================

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_SECRET=YOUR_SUPER_SECRET_KEY_HERE_MIN_256_BITS
JWT_EXPIRATION_MS=86400000

# ──────────────────────────────────────────
# PostgreSQL (superusuario de cada instancia)
# POSTGRES_DB define el nombre de la base de datos que crea el
# contenedor al inicializarse (debe coincidir con la URL JDBC).
# ──────────────────────────────────────────
POSTGRES_USER=donatech
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=donatech

# ──────────────────────────────────────────
# Passwords por microservicio
# Usadas en db/postgres-*/01-init.sh (crea el usuario DB)
# y en los Spring profiles docker (conecta el servicio).
# ──────────────────────────────────────────
USERS_DB_PASS=cambiar_por_contraseña_segura
CATALOG_DB_PASS=cambiar_por_contraseña_segura
ORDER_DB_PASS=cambiar_por_contraseña_segura
SUPPORTS_DB_PASS=cambiar_por_contraseña_segura
SHIPPING_DB_PASS=cambiar_por_contraseña_segura

# ──────────────────────────────────────────
# RabbitMQ
# ──────────────────────────────────────────
RABBITMQ_DEFAULT_USER=donatech
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password
RABBITMQ_USER=donatech
RABBITMQ_PASS=your_rabbitmq_password

# ──────────────────────────────────────────
# Frontend URL (sin barra al final)
# - CORS del API Gateway (con Caddy es same-origin → CORS no aplica, se deja).
# - Link de soporte en correos de entrega (order-service): se construye como
#   {FRONTEND_URL}/support/delivery-issue?orderId={id}.
# Usar la URL PÚBLICA del entorno:
#   cloud (Droplet+Caddy): https://donatech.onieto.cl
#   local (PC+cloudflared): https://donatechl.onieto.cl
# ──────────────────────────────────────────
FRONTEND_URL=https://donatech.onieto.cl

# ──────────────────────────────────────────
# Caddy reverse proxy + TLS (solo docker-compose-cloud.yml / Droplet)
# SITE_DOMAIN: dominio que sirve Caddy (debe ser A-record DNS-only al Droplet).
# ACME_EMAIL: correo para avisos de Let's Encrypt (recomendado).
# ──────────────────────────────────────────
SITE_DOMAIN=donatech.onieto.cl
ACME_EMAIL=tucorreo@dominio.cl

# ──────────────────────────────────────────
# SMTP — notification-service
#
# OPCIÓN A — Mailtrap (sandbox, NO entrega a bandejas reales):
#   https://mailtrap.io → Inboxes → SMTP Settings
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#
# OPCIÓN B — Gmail (entrega REAL a bandejas):
#   1. Activar verificación en 2 pasos en la cuenta Google.
#   2. Generar una "Contraseña de aplicación" (16 dígitos):
#      https://myaccount.google.com/apppasswords
#   3. Usar la config de abajo. IMPORTANTE: MAIL_FROM debe ser la
#      MISMA cuenta Gmail de SMTP_USER, o Gmail rechaza el envío.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tucuenta@gmail.com
#   SMTP_PASS=xxxxxxxxxxxxxxxx   # App Password sin espacios
#   MAIL_FROM=tucuenta@gmail.com
# ──────────────────────────────────────────
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
MAIL_FROM=noreply@donatech.cl

# ──────────────────────────────────────────
# Backup offsite — DigitalOcean Spaces (servicio db-backup)
# Crear bucket Spaces (Private) + Spaces API Key en DigitalOcean.
# El sidecar db-backup hace pg_dump diario (03:00) y sube a este bucket
# bajo prefijo cloud/ (Droplet) o local/ (PC). Reutiliza POSTGRES_USER/PASSWORD.
# Si SPACES_BUCKET queda vacío -> solo backup local (sin offsite).
# SPACES_ENDPOINT: región del bucket, p.ej. https://nyc3.digitaloceanspaces.com
# ──────────────────────────────────────────
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=donatech-backups
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# TZ=America/Santiago   # opcional: hora local para el cron
