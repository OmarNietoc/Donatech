# Configuración global
JWT_SECRET=YOUR_SUPER_SECRET_KEY_HERE_MIN_256_BITS
JWT_EXPIRATION_MS=86400000

# Base de Datos PostgreSQL
POSTGRES_USER=donatech
POSTGRES_PASSWORD=your_secure_password

# Passwords BD por microservicio (usadas en init-schemas.sh y Spring docker profile)
CATALOG_DB_PASS=cambiar_por_contraseña
ORDER_DB_PASS=cambiar_por_contraseña
USERS_DB_PASS=cambiar_por_contraseña
SUPPORTS_DB_PASS=cambiar_por_contraseña
SHIPPING_DB_PASS=cambiar_por_contraseña

# RabbitMQ
RABBITMQ_DEFAULT_USER=donatech
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password
RABBITMQ_USER=donatech
RABBITMQ_PASS=your_rabbitmq_password

# SMTP (notification-service)
# Para desarrollo usar Mailtrap: https://mailtrap.io → Inboxes → SMTP Settings
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
MAIL_FROM=noreply@donatech.cl
