# ─── Proveedor LLM: "cloud" (DeepSeek/Groq/OpenAI compatible) o "ollama" ──
LLM_PROVIDER=cloud

# Proveedor cloud (formato OpenAI). Ejemplos:
#   DeepSeek: base_url=https://api.deepseek.com           model=deepseek-chat
#   Groq:     base_url=https://api.groq.com/openai/v1      model=llama-3.3-70b-versatile
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Ollama (fallback local)
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.2:3b

# ─── Embeddings ──────────────────────────────────────────────────────────
EMBEDDINGS_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ─── Base de datos PostgreSQL (SOLO LECTURA, schema catalog) ──────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=donatech
DB_USER=catalog_user
DB_PASSWORD=
DB_SCHEMA=catalog

# ─── Spring ms catalog (creación de kits) ─────────────────────────────────
MS_KITS_URL=http://localhost:8081

# ─── Service discovery (Eureka) ───────────────────────────────────────────
# Vacío = registro en Eureka deshabilitado (modo standalone)
EUREKA_SERVER_URL=
APP_NAME=kit-ia-service
APP_HOST=localhost
APP_PORT=8001

# ─── App ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Umbrales y reglas ─────────────────────────────────────────────────────
SIMILARITY_THRESHOLD_HIGH=0.75
SIMILARITY_THRESHOLD_LOW=0.50
MAX_CHAT_TURNS=3
MAX_QUESTIONS_PER_TURN=2
MIN_PRODUCTS_PER_KIT=6
SESSION_TTL_MINUTES=30
